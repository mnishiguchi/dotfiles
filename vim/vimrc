" ============================================================================
" Large file behavior
" ============================================================================

function! s:ApplyLargeFileDefaults() abort
  let l:file_path = expand('<afile>:p')

  if l:file_path ==# ''
    return
  endif

  if getfsize(l:file_path) > 1024 * 1024
    setlocal noswapfile

    if has('persistent_undo')
      setlocal noundofile
    endif

    let b:large_file = 1
  endif
endfunction

function! s:ApplyLargeFileWindowDefaults() abort
  if get(b:, 'large_file', 0)
    setlocal syntax=
    setlocal foldmethod=manual
    echo 'Large file detected. Performance settings applied.'
  endif
endfunction

augroup vimrc_large_files
  autocmd!
  autocmd BufReadPre * call <SID>ApplyLargeFileDefaults()
  autocmd BufWinEnter * call <SID>ApplyLargeFileWindowDefaults()
augroup END

" ============================================================================
" Auto-reload files changed outside Vim
" ============================================================================

augroup vimrc_autoread
  autocmd!
  autocmd FocusGained,BufEnter * checktime
augroup END

" ============================================================================
" Filetype tweaks
" ============================================================================

augroup vimrc_filetypes
  autocmd!

  " Markdown-ish
  autocmd BufRead,BufNewFile *.livemd setfiletype markdown
  autocmd BufRead,BufNewFile *.mdx setfiletype markdown

  " Rails / ERB
  autocmd BufRead,BufNewFile *.erb setfiletype eruby

  " Go templates
  autocmd BufRead,BufNewFile *.gotmpl setfiletype gotmpl

  " Ruby
  autocmd BufRead,BufNewFile Gemfile,Rakefile,Vagrantfile,Thorfile,Guardfile,config.ru setfiletype ruby
  autocmd BufRead,BufNewFile *.rake,*.jbuilder setfiletype ruby

  " YAML variants
  autocmd BufRead,BufNewFile docker-compose.yml,docker-compose.yaml,.gitlab-ci.yml setfiletype yaml
  autocmd BufRead,BufNewFile */values.yml,*/values.yaml,*/values.*.yml,*/values.*.yaml setfiletype yaml
