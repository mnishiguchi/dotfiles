" Add blank lines above/below without entering insert mode.
function! s:AddBlankLinesAbove(count) abort
  let l:count = a:count > 0 ? a:count : 1
  let l:view = winsaveview()

  call append(line('.') - 1, repeat([''], l:count))

  let l:view.lnum += l:count
  call winrestview(l:view)
endfunction

function! s:AddBlankLinesBelow(count) abort
  let l:count = a:count > 0 ? a:count : 1
  let l:view = winsaveview()

  call append(line('.'), repeat([''], l:count))

  call winrestview(l:view)
endfunction

nnoremap <silent> [<Space> :<C-u>call <SID>AddBlankLinesAbove(v:count1)<CR>
nnoremap <silent> ]<Space> :<C-u>call <SID>AddBlankLinesBelow(v:count1)<CR>

" Approximate Neovim LSP-style references.
" This uses fzf.vim + ripgrep when available.
function! s:SearchReferencesUnderCursor() abort
  let l:word = expand('<cword>')

  if l:word ==# ''
    return
  endif

  if exists(':Rg') == 2
    execute 'Rg ' . shellescape(l:word)
  elseif executable('rg')
    execute 'grep! ' . shellescape(l:word)
    copen
  else
    execute 'vimgrep /\V' . escape(l:word, '/\') . '/gj **/*'
    copen
  endif
endfunction

nnoremap <silent> gr :<C-u>call <SID>SearchReferencesUnderCursor()<CR>

