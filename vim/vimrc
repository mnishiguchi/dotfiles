scriptencoding utf-8

" ============================================================================
" Core defaults
" ============================================================================

set nocompatible
set encoding=utf-8

syntax enable
filetype plugin indent on

set number
set cursorline
set scrolloff=8
set nowrap

set backspace=indent,eol,start
set mouse=a
set hidden
set autoread
set history=1000

" Avoid auto-wrapping while typing.
set formatoptions-=t

" Search
set ignorecase
set smartcase
set incsearch
set nohlsearch

" Tabs / indent
set tabstop=2
set softtabstop=2
set shiftwidth=2
set expandtab
set autoindent
set smartindent

if exists('+breakindent')
  set breakindent
endif

" UI / appearance
set background=dark

if exists('+termguicolors')
  set termguicolors
endif

if exists('+colorcolumn')
  set colorcolumn=80
endif

if exists('+signcolumn')
  set signcolumn=yes
endif

" netrw
let g:netrw_banner = 0

" Clipboard
if has('clipboard')
  set clipboard=unnamedplus
endif

" Diff defaults
set diffopt+=vertical

" Command-line completion
set path+=**
set wildmenu
set wildmode=longest:full,full

if exists('+completeopt')
  set completeopt=menuone,noselect
endif

" Responsiveness
set updatetime=300
set timeoutlen=500
set lazyredraw

if exists('+synmaxcol')
  set synmaxcol=200
endif

if exists('+redrawtime')
  set redrawtime=10000
endif

" Filename / keyword tweaks
set isfname+=@-@
set iskeyword+=-

" Persistent undo
if has('persistent_undo')
  set undofile

  let s:undo_dir = expand('~/.vim/undo')

  if !isdirectory(s:undo_dir)
    call mkdir(s:undo_dir, 'p')
  endif

  let &undodir = s:undo_dir
endif

" ============================================================================
" Plugin bootstrap
" ============================================================================

let s:plug_vim = expand('~/.vim/autoload/plug.vim')

if empty(glob(s:plug_vim))
  silent execute '!curl -fLo ' . shellescape(s:plug_vim) . ' --create-dirs https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim'
  autocmd VimEnter * PlugInstall --sync | source $MYVIMRC
endif

" Vimwiki reads these during startup, so define them before plug#end.
let g:vimwiki_list = [
      \ {
      \   'path': '~/Documents/vimwiki/',
      \   'syntax': 'markdown',
      \   'ext': '.md'
      \ }
      \ ]

let g:vimwiki_global_ext = 0

call plug#begin('~/.vim/plugged')

" Theme / UI
Plug 'kaicataldo/material.vim'
Plug 'itchyny/lightline.vim'
Plug 'Yggdroot/indentLine'

" Editing helpers
Plug 'jiangmiao/auto-pairs'
Plug 'tpope/vim-surround'
Plug 'tpope/vim-commentary'
Plug 'tpope/vim-abolish'
Plug 'mbbill/undotree'

" Git
Plug 'tpope/vim-fugitive'
Plug 'tpope/vim-rhubarb'
Plug 'mhinz/vim-signify'
Plug 'APZelos/blamer.nvim'

" LSP
Plug 'prabirshrestha/vim-lsp'
Plug 'mattn/vim-lsp-settings'

" Formatting
Plug 'sbdchd/neoformat'

" Fuzzy finder
Plug 'junegunn/fzf', { 'do': { -> fzf#install() } }
Plug 'junegunn/fzf.vim'

" Notes
Plug 'vimwiki/vimwiki'

call plug#end()

