" ============================================================================

function! s:FormatWithPrettier() abort
  if executable('prettier')
    execute '%!prettier --stdin-filepath ' . shellescape(expand('%:p'))
    return
  endif

  if executable('npx')
    execute '%!npx --no-install prettier --stdin-filepath ' . shellescape(expand('%:p'))
    return
  endif

  echo 'prettier is not available'
endfunction

command! FormatRuby     silent execute '%!bundle exec rubocop -A --stdin ' . shellescape(expand('%:p'))
command! FormatJson     call <SID>FormatWithPrettier()
command! FormatMarkdown call <SID>FormatWithPrettier()
command! FormatYaml     call <SID>FormatWithPrettier()
command! FormatXml      silent execute '%!xmllint --format -'
command! FormatSh       silent execute '%!shfmt -i 2 -ci'

function! s:FormatCurrentBuffer() abort
  " Prefer LSP formatting when an LSP plugin provides the command.
  if exists(':LspDocumentFormatSync') == 2
    silent! LspDocumentFormatSync
    return
  endif

  if exists(':LspDocumentFormat') == 2
    silent! LspDocumentFormat
    return
  endif

  " coc.nvim compatibility, in case this .vimrc is used with coc later.
  if exists(':CocCommand') == 2
    silent! CocCommand editor.action.formatDocument
    return
  endif

  " Direct fallback by filetype.
  " Put these before Neoformat so important common filetypes work reliably.
  if &filetype ==# 'ruby'
    FormatRuby
    return
  endif

  if &filetype ==# 'json' || &filetype ==# 'jsonc'
    FormatJson
    return
  endif

  if &filetype ==# 'markdown'
    FormatMarkdown
    return
  endif

  if &filetype ==# 'yaml'
    FormatYaml
    return
  endif

  if &filetype ==# 'xml'
    FormatXml
    return
  endif

  if &filetype ==# 'sh' || &filetype ==# 'bash' || &filetype ==# 'zsh'
    FormatSh
    return
  endif

  " General formatter plugin fallback.
  if exists(':Neoformat') == 2
    silent! Neoformat
    return
  endif

  echo 'No formatter configured for filetype: ' . &filetype
endfunction

nnoremap <leader>lf :call <SID>FormatCurrentBuffer()<CR>

