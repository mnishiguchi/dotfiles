y() {
  local tmp
  local newcwd
  local cd_status

  if ! command -v yazi >/dev/null 2>&1; then
    echo "y: yazi not found" >&2
    return 127
  fi

  tmp="$(mktemp -t yazi-cwd.XXXXXX)"

  command yazi "$@" --cwd-file="$tmp"

  if [[ -f "$tmp" ]]; then
    newcwd="$(sed 's/^[[:space:]]*//; s/[[:space:]]*$//' "$tmp")"

    if [[ -n "$newcwd" ]]; then
      if [[ "$newcwd" != "$PWD" ]]; then
        cd -- "$newcwd"
        cd_status="$?"
        rm -f -- "$tmp"
        return "$cd_status"
      fi
    fi

    rm -f -- "$tmp"
  fi
}

