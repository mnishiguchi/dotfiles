mkarchive() {
  local output
  local files

  if [[ "$#" -lt 2 ]]; then
    echo "usage: mkarchive <output> <files/dirs...>" >&2
    return 2
  fi

  output="$1"
  shift
  files=("$@")

  case "$output" in
  *.tar)
    tar -cvf "$output" -- "${files[@]}"
    ;;
  *.tar.gz | *.tgz)
    tar -cvf - -- "${files[@]}" | gzip -c >"$output"
    ;;
  *.zip)
    zip -r -X -- "$output" "${files[@]}"
    ;;
  *)
    echo "mkarchive: unsupported extension: $output" >&2
    echo "supported: .tar .tar.gz(.tgz) .zip" >&2
    return 1
    ;;
  esac
}

mkgpg() {
  local base
  local files
  local tarball
  local encrypted_file

  if [[ "$#" -lt 2 ]]; then
    echo "usage: mkgpg <basename> <files/dirs...>" >&2
    return 2
  fi

  base="$1"
  shift
  files=("$@")

  tarball="$base.tar.gz"
  encrypted_file="$base.tar.gz.gpg"

  tar -cvf - -- "${files[@]}" | gzip -c >"$tarball"

  if gpg --symmetric --cipher-algo AES256 --output "$encrypted_file" --quiet --batch "$tarball"; then
    rm -f -- "$tarball"
  else
    echo "gpg encryption failed (leaving plaintext: $tarball)" >&2
    return 1
  fi
}

extract() {
  local archive

  if [[ "$#" -lt 1 ]]; then
    echo "usage: extract <archive>" >&2
    return 2
  fi

  archive="$1"

  case "$archive" in
  *.tar)
    tar xvf "$archive"
    ;;
  *.tar.gz | *.tgz)
    tar xvzf "$archive"
    ;;
  *.zip | *.ZIP)
    unzip -- "$archive"
    ;;
  *.gz)
    gunzip --keep -- "$archive"
    ;;
  *)
    echo "extract: unsupported archive: $archive" >&2
    echo "supported: .tar .tar.gz(.tgz) .zip [.gz single-file]" >&2
    return 1
    ;;
  esac
}

capslock() {
  local mode

  if ! command -v setxkbmap >/dev/null 2>&1; then
    echo "capslock: setxkbmap not found" >&2
    return 1
  fi

  if [[ "$#" -lt 1 ]]; then
    echo "usage: capslock on|off" >&2
    return 2
  fi

  mode="${1,,}"

  case "$mode" in
  on)
    setxkbmap -option
    ;;
  off)
    setxkbmap -option ctrl:nocaps
    ;;
  *)
    echo "usage: capslock on|off" >&2
    return 2
    ;;
  esac
}

## Prompt

if [[ -z "${debian_chroot:-}" ]]; then
  if [[ -r /etc/debian_chroot ]]; then
    debian_chroot="$(cat /etc/debian_chroot)"
  fi
fi

git_branch_prompt() {
  local branch

  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    return 0
  fi

  branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null)"

  if [[ -z "$branch" ]]; then
    branch="$(git rev-parse --short HEAD 2>/dev/null)"
  fi

  if [[ -n "$branch" ]]; then
    printf " (%s)" "$branch"
  fi
}

bash_prompt() {
  local last_status
  local normal
  local bold_red
  local bold_green
  local magenta
  local green
  local bold_blue
  local user_color
  local prompt_color
  local chroot_part
  local title_part
  local git_part

  last_status="$?"

  normal="\[\e[0m\]"
  bold_red="\[\e[1;31m\]"
  bold_green="\[\e[1;32m\]"
  magenta="\[\e[35m\]"
  green="\[\e[32m\]"
  bold_blue="\[\e[1;34m\]"

  chroot_part=""
  title_part=""
  git_part=""

  if [[ -n "${debian_chroot:-}" ]]; then
    chroot_part="($debian_chroot)"
  fi

  case "$TERM" in
  xterm* | rxvt*)
    title_part="\[\e]0;${chroot_part}\u@\h: \w\a\]"
    ;;
  *)
    ;;
  esac

  if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
    user_color="$bold_red"
  else
    user_color="$magenta"
  fi

  if [[ "$last_status" -eq 0 ]]; then
    prompt_color="$bold_green"
  else
    prompt_color="$bold_red"
  fi

  git_part="$(git_branch_prompt)"

  PS1="${title_part}${chroot_part}${user_color}\u${normal}@${green}\h${normal}:${bold_blue}\w${normal}${git_part}"$'\n'"${prompt_color}$ ${normal}"

  return "$last_status"
}

prepend_prompt_command() {
  local command_to_add
  local prompt_command_declaration
  local existing_command

  command_to_add="$1"
  prompt_command_declaration="$(declare -p PROMPT_COMMAND 2>/dev/null || true)"

  if [[ "$prompt_command_declaration" == declare\ -a* ]] || [[ "$prompt_command_declaration" == declare\ -ax* ]]; then
    for existing_command in "${PROMPT_COMMAND[@]}"; do
      if [[ "$existing_command" == "$command_to_add" ]]; then
        return 0
      fi
    done

    PROMPT_COMMAND=("$command_to_add" "${PROMPT_COMMAND[@]}")
  else
    if [[ -z "${PROMPT_COMMAND:-}" ]]; then
      PROMPT_COMMAND="$command_to_add"
    else
      case ";$PROMPT_COMMAND;" in
      *";$command_to_add;"*)
        ;;
      *)
        PROMPT_COMMAND="$command_to_add; $PROMPT_COMMAND"
        ;;
      esac
    fi
  fi
}

prepend_prompt_command bash_prompt
